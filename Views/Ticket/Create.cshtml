@model BusTicketing.DTOs.CreateTicketInputDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var fromMunicipalityName = "";
    var toMunicipalityName = "";
    var fromBarangayName = "";
    var toBarangayName = "";

    if (ViewBag.Municipalities is List<SelectListItem> municipalitiesList)
    {
        fromMunicipalityName = municipalitiesList.FirstOrDefault(x => x.Value == Model.FromMunicipalityId.ToString())?.Text ?? "";
        toMunicipalityName = municipalitiesList.FirstOrDefault(x => x.Value == Model.ToMunicipalityId.ToString())?.Text ?? "";
    }

    if (ViewBag.FromBarangays is List<SelectListItem> fromBarangaysList)
    {
        fromBarangayName = fromBarangaysList.FirstOrDefault(x => x.Value == Model.FromBarangayId.ToString())?.Text ?? "";
    }

    if (ViewBag.ToBarangays is List<SelectListItem> toBarangaysList)
    {
        toBarangayName = toBarangaysList.FirstOrDefault(x => x.Value == Model.ToBarangayId.ToString())?.Text ?? "";
    }
}

<div class="page-panel">
    <div class="form-card">
        <div class="card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
                <div>
                    <span class="eyebrow">New Ticket</span>
                    <h2 class="section-heading">Create Ticket</h2>
                </div>
                <div class="text-muted">Fill in the details and see the estimated distance and fare automatically.</div>
            </div>

            <form asp-action="Create" method="post" id="ticketForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="text-white mb-3">From</h5>

                        <div class="mb-3">
                            <label asp-for="FromMunicipalityId" class="form-label">From Municipality</label>
                            <select asp-for="FromMunicipalityId" class="form-control" id="FromMunicipalityId">
                                <option value="">Select municipality...</option>
                                @if (ViewBag.Municipalities is List<SelectListItem> municipalityOptions)
                                {
                                    foreach (var municipalityItem in municipalityOptions)
                                    {
                                        <option value="@municipalityItem.Value">@municipalityItem.Text</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="FromMunicipalityId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">From Barangay</label>
                            <div style="position: relative;">
                                <div class="input-group" id="FromBarangaySearchGroup">
                                    <input type="text" id="FromBarangaySearch" class="form-control" placeholder="Select municipality first..." value="@fromBarangayName" autocomplete="off" disabled />
                                    <button class="btn btn-outline-secondary" type="button" id="FromBarangayDropdownBtn" title="Show all">
                                        ▼
                                    </button>
                                </div>
                                <div id="FromBarangayDropdown" class="dropdown-list" style="display: none; max-height: 250px; overflow-y: auto; border: 1px solid #dee2e6; position: absolute; width: 100%; z-index: 1100; background: white; top: 100%; left: 0; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border-radius: 0 0 4px 4px;"></div>
                            </div>
                            <input asp-for="FromBarangayId" type="hidden" id="FromBarangayId" />
                            <span asp-validation-for="FromBarangayId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5 class="text-white mb-3">To</h5>

                        <div class="mb-3">
                            <label asp-for="ToMunicipalityId" class="form-label">To Municipality</label>
                            <select asp-for="ToMunicipalityId" class="form-control" id="ToMunicipalityId">
                                <option value="">Select municipality...</option>
                                @if (ViewBag.Municipalities is List<SelectListItem> municipalityOptionsTo)
                                {
                                    foreach (var municipalityItem in municipalityOptionsTo)
                                    {
                                        <option value="@municipalityItem.Value">@municipalityItem.Text</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ToMunicipalityId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">To Barangay</label>
                            <div style="position: relative;">
                                <div class="input-group" id="ToBarangaySearchGroup">
                                    <input type="text" id="ToBarangaySearch" class="form-control" placeholder="Select municipality first..." value="@toBarangayName" autocomplete="off" disabled />
                                    <button class="btn btn-outline-secondary" type="button" id="ToBarangayDropdownBtn" title="Show all">
                                        ▼
                                    </button>
                                </div>
                                <div id="ToBarangayDropdown" class="dropdown-list" style="display: none; max-height: 250px; overflow-y: auto; border: 1px solid #dee2e6; position: absolute; width: 100%; z-index: 1100; background: white; top: 100%; left: 0; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border-radius: 0 0 4px 4px;"></div>
                            </div>
                            <input asp-for="ToBarangayId" type="hidden" id="ToBarangayId" />
                            <span asp-validation-for="ToBarangayId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-4">
                        <label asp-for="Distance" class="form-label">Distance (km)</label>
                        <input asp-for="Distance" type="number" step="0.01" min="0.01" class="form-control" id="Distance" readonly />
                        <span asp-validation-for="Distance" class="text-danger"></span>
                    </div>
    
                    <div class="col-md-4">
                        <label class="form-label">Recommended Fare</label>
                        <div class="d-flex align-items-center gap-3">
                            <span id="recommendedFare" class="fs-4 text-white">-</span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Fare" class="form-label">Final Fare</label>
                        <input asp-for="Fare" type="number" step="0.01" min="0" class="form-control" id="Fare" readonly />
                        <span asp-validation-for="Fare" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex flex-column flex-sm-row gap-3">
                    <button type="submit" class="btn btn-success btn-lg">Create Ticket</button>
                    <a class="btn btn-outline-secondary btn-lg" href="/">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
